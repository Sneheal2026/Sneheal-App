# ─────────────────────────────────────────────────────────────
# Sneheal monorepo — shared ignore rules (frontend + backend)
# ─────────────────────────────────────────────────────────────

# Dependencies (never commit installed packages)
node_modules/

# Environment & secrets
.env
.env.local
.env.*.local
!.env.example

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Test / coverage
coverage/
.nyc_output/

# Build outputs
dist/
build/
out/
tmp/
temp/

# TypeScript
*.tsbuildinfo

# Cursor / local tooling (optional)
.cursor/
