# Google Maps — native map tiles, Directions API (route polylines), Geocoding
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Backend API (required for auth, prescriptions, etc.)
# Emulator: Android → 10.0.2.2:5000 | iOS simulator → localhost:5000
# Physical device → your PC's LAN IP, e.g. http://192.168.1.100:5000
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# Dev only — skip OTP/registration when backend is unavailable (__DEV__ also enables this)
EXPO_PUBLIC_SKIP_AUTH=true
