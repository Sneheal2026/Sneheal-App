{
  "expo": {
    "name": "SnehealApp",
    "slug": "sneheal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sneheal.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow Sneheal to use the microphone for voice search.",
        "NSSpeechRecognitionUsageDescription": "Allow Sneheal to use speech recognition for voice search.",
        "NSLocationWhenInUseUsageDescription": "Sneheal uses your location to show your delivery address and nearby pharmacies.",
        "LSApplicationQueriesSchemes": [
          "whatsapp"
        ]
      }
    },
    "android": {
      "package": "com.sneheal.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon-48.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Sneheal-Logoo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Sneheal to access your photos to upload prescriptions and medicine images.",
          "cameraPermission": "Allow Sneheal to use your camera to photograph prescriptions and medicines."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Sneheal to use the microphone for voice search.",
          "speechRecognitionPermission": "Allow Sneheal to use speech recognition for voice search."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Sneheal to use your location for delivery and map."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A73E8",
          "defaultChannel": "medicine-reminders",
          "mode": "production"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "524aaef6-ed32-40a3-a976-30bf6133d0c7"
      }
    }
  }
}
