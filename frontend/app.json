{
  "expo": {
    "name": "SnehealApp",
    "slug": "sneheal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sneheal needs your location to deliver medicines to your exact address."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#1A73E8",
        "foregroundImage": "./assets/images/Sneheal-Logoo.png",
        "backgroundImage": "./assets/images/Sneheal-Logoo.png",
        "monochromeImage": "./assets/images/Sneheal-Logoo.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Sneheal-Logoo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Sneheal to access your photos to upload your Aadhar card.",
          "cameraPermission": "Allow Sneheal to use your camera to photograph your Aadhar card."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sneheal needs your location to deliver medicines to your exact address."
        }
      ]
    ]
  }
}
